.post.m-1{ id: post_element_id(post) }
  = render "shared/user_button", user_id: post.user_id, user_name: post.user_name
  .post-content.p-2.rounded-3= post.content
  .post-created-at= post.created_at.strftime("%Y/%m/%d %H:%M")
  .like-controls.d-inline-block.my-1
    = render "like_button", post: post, liked: current_user.liked_post_ids.include?(post.id)
    = turbo_frame_tag post_element_id(post, :likers), class: "likers"
