= render "users/shared/modal", resource: resource, resource_name: resource_name, url: password_path(resource_name), title: "パスワード再設定", submit: "再設定の手順をメールで受信する" do |f|
  .field
    = f.label :email, class: "form-label"
    = f.email_field :email, autofocus: true, autocomplete: "email", required: true, class: "form-control"
