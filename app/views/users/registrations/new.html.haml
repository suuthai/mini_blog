= render "users/shared/modal", resource: resource, resource_name: resource_name, url: registration_path(resource_name), title: "ユーザー登録", submit: "ユーザー登録する" do |f|
  .field
    = f.label :name, class: "form-label"
    %span (必須、20文字以内、アルファベットのみ)
    = f.text_field :name, autofocus: true, maxlength: 20, required: true, pattern: "[a-zA-Z]+", class: "form-control"
  .field.mt-2
    = f.label :email, class: "form-label"
    %span (必須)
    = f.email_field :email, autocomplete: "email", required: true, class: "form-control"
  .field.mt-2
    = f.label :password, class: "form-label"
    - if @minimum_password_length
      %span (#{@minimum_password_length}文字以上)
    = f.password_field :password, autocomplete: "new-password", minlength: @minimum_password_length, required: true, class: "form-control"
  .field.mt-2
    = f.label :password_confirmation, class: "form-label"
    = f.password_field :password_confirmation, autocomplete: "new-password", minlength: @minimum_password_length, required: true, class: "form-control"
  .field.mt-2
    = f.label :profile_text, class: "form-label"
    %span (200文字以内)
    = f.text_area :profile_text, maxlength: 200, class: "form-control"
  .field.mt-2
    = f.label :blog_url, class: "form-label"
    = f.text_field :blog_url, class: "form-control"
    